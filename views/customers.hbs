<!-- customers.hbs -->
<script src="http://ajax.googleapis.com/ajax/libs/jquery/1.9.1/jquery.min.js"></script>

{{!-- Create a table --}}
<table id="customers-table">

    {{!-- Header section --}}
    <thead>

        {{!-- For just the first row, we print each key of the row object as a header cell so we
        know what each column means when the page renders --}}
        <tr>
            {{#each data.[0]}}
            <th>
                {{@key}}
            </th>
            {{/each}}
            <th>delete</th>
        </tr>
    </thead>

    {{!-- Body section --}}
    <tbody>

        {{!-- For each row, print the id, fname, lname, homeworld and age, in order --}}
        {{#each data}}
        <tr data-value={{this.customerID}}>
            <td>{{this.customerID}}</td>
            <td>{{this.firstName}}</td>
            <td>{{this.lastName}}</td>
            <td>{{this.phoneNumber}}</td>
            <td>{{this.email}}</td>
            <td><button onclick="deleteCustomer({{this.customerID}})">Delete</button></td>
        </tr>
        {{/each}}
    </tbody>
</table>

<!-- /views/customers.hbs -->
<h2>Add a Customer</h2>
<p>To add a new customer, please enter the information below and click `Submit`.</p>
<form id="add-customer-form" method="POST" action="/add-customer-form">
    <label for="input-firstName">First Name: </label>
    <input type="text" name="input-firstName" id="input-firstName-html">
    
    <label for="input-lastName">Last Name: </label>
    <input type="text" name="input-lastName" id="input-lastName-html">

    <label for="input-phoneNumber">Phone Number: </label>
    <input type="tel" name="input-phoneNumber" id="input-phoneNumber-html">

    <label for="input-lastName">Email: </label>
    <input type="email" name="input-email" id="input-email-html">

    <input type="submit">
</form>

<h2>Updating A Customer's Phone Number</h2>
<p>To update a customer's contact information, select their name from the drop down list, then enter their new phone number.
</p>
<form id="update-customer-form-ajax">

    <label for="input-customerID">Full Name: </label>
    <select name="input-customerID" id="mySelect">
        <option value="test">Select a Person</option>
        {{#each data}}
        <option value="{{this.customerID}}">{{this.firstName}} {{this.lastName}}</option>
        {{/each}}
    </select>   

    <label for="input-phoneNumber">Phone Number: </label>
    <input type="text" name="input-phoneNumber" id="customer-update-phoneNumber">

    <input type="submit">
</form>

<script src="./js/update_customer.js"></script>
<script src="./js/delete_customer.js"></script>
